# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/omnipreneur"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@omnipreneur.com"
CONTACT_EMAIL="contact@omnipreneur.com"

# AI API Keys
OPENAI_API_KEY="sk-your-openai-api-key"
CLAUDE_API_KEY="sk-your-claude-api-key"
OPENROUTER_API_KEY="sk-your-openrouter-api-key"

# Payment Processing
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Application URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
GOOGLE_TAG_MANAGER_ID="GTM-XXXXXXX"

# Performance Monitoring (Optional)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Feature Flags
ENABLE_ANALYTICS="true"
ENABLE_PAYMENTS="true"
ENABLE_EMAIL="true"
ENABLE_AI_FEATURES="true"

# Development
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1" 